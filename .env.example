# Application
DATABASE_URL=postgresql+asyncpg://infrapredict:infrapredict@localhost:5432/infrapredict
TEST_DATABASE_URL=postgresql+asyncpg://infrapredict:infrapredict@localhost:5432/infrapredict_test

# Security — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated frontend origins
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173

# Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Optional: external services
# OPENWEATHER_API_KEY=
# ML_MODEL_ENDPOINT=http://localhost:9000/predict
